[bandit]
# Bandit configuration for Amazon SES Campaign Manager project
# This file suppresses false positive security warnings
# Generated: 2025-11-24

# Exclude test files and virtual environments
exclude_dirs = /tests/,/venv/,/.venv/,/__pycache__/

# Skip specific tests that generate false positives
skips = B110,B404,B603,B607,B608

# B110: Try/Except/Pass - Intentional defensive programming for UI widgets
# B404: Import subprocess - Used safely for opening files and listing profiles
# B603: Subprocess without shell=True - Safe as we control all commands
# B607: Starting process with partial path - System commands are safe
# B608: SQL injection via string formatting - No user input, safe

# Individual line-level suppressions are also used in code with:
# # nosec B324 - MD5 used for cache keys, not security
